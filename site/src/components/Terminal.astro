---
interface Props {
  title?: string;
  ariaLabel?: string;
}
const { title = "terminal", ariaLabel = "Terminal example" } = Astro.props;
---

<figure class="terminal" aria-label={ariaLabel}>
  <div class="term-header">
    <div class="term-dots" aria-hidden="true">
      <span class="d1"></span><span class="d2"></span><span class="d3"></span>
    </div>
    <span class="term-title">{title}</span>
  </div>
  <div class="term-body">
    <slot />
  </div>
</figure>

<style is:global>
  .terminal {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 0;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    line-height: 1.85;
    max-width: 100%;
  }
  .term-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--ink-06);
    border-bottom: 1px solid var(--hairline);
  }
  .term-dots {
    display: flex;
    gap: 6px;
  }
  .term-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .term-dots .d1 {
    background: #ff5f57;
  }
  .term-dots .d2 {
    background: #febc2e;
  }
  .term-dots .d3 {
    background: #28c840;
  }
  .term-title {
    color: var(--text-muted);
    font-size: 0.8125rem;
  }
  .term-body {
    padding: 20px 22px;
    overflow-x: auto;
  }
  .term-line {
    white-space: pre-wrap;
    word-break: break-word;
  }
  .term-prompt {
    color: var(--accent-bright);
  }
  .term-out {
    color: var(--text-muted);
  }
  .term-good {
    color: var(--proceed);
  }
  .term-review {
    color: var(--review);
  }
  .term-block {
    color: var(--block);
  }
  .term-good-b {
    color: var(--proceed);
    font-weight: 700;
  }
  .term-review-b {
    color: var(--review);
    font-weight: 700;
  }
  .term-block-b {
    color: var(--block);
    font-weight: 700;
  }
  /* Mirrors the CLI's semantic ANSI scheme. */
  .term-path {
    color: var(--term-cyan);
  } /* cyan file paths */
  .term-conf {
    color: var(--term-cyan);
  } /* cyan confidence / calibration band */
  .term-label {
    color: var(--text);
    font-weight: 700;
  } /* bold headers/labels */
  .term-dim {
    color: var(--text-dim);
  } /* dim secondary text */
  /* The █/░ risk meter, tinted by verdict level (filled) vs dim (empty track). */
  .meter-fill-proceed {
    color: var(--proceed);
  }
  .meter-fill-review {
    color: var(--review);
  }
  .meter-fill-block {
    color: var(--block);
    font-weight: 700;
  }
  .meter-track {
    color: var(--text-dim);
  }
  .term-comment {
    color: var(--text-dim);
    font-style: italic;
  }
  .blink {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: var(--sheen);
    vertical-align: middle;
    margin-left: 2px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .blink {
      animation: blink 1.1s infinite;
    }
    @keyframes blink {
      0%,
      49% {
        opacity: 1;
      }
      50%,
      100% {
        opacity: 0;
      }
    }
  }
</style>
