---
import { getCollection } from "astro:content";
import { base } from "../lib/path";
const all = await getCollection("docs");
const sectionOrder = ["Getting started", "Reference", "Integration"] as const;
const grouped = sectionOrder.map((name) => ({
  name,
  items: all
    .filter((d) => d.data.section === name)
    .sort((a, b) => a.data.order - b.data.order),
}));
const current = Astro.url.pathname.replace(/\/$/, "");
const linkFor = (slug: string) => {
  const clean = slug === "index" ? "" : `/${slug}`;
  return `${base}docs${clean}`.replace(/\/+/g, "/");
};
---

<aside class="sidebar" aria-label="Documentation navigation">
  {
    grouped.map((group) => (
      <>
        <h2 class="section-title">{group.name}</h2>
        <ul>
          {group.items.map((item) => {
            const href = linkFor(item.slug);
            const active = href.replace(/\/$/, "") === current;
            return (
              <li>
                <a
                  href={href}
                  class={active ? "active" : ""}
                  aria-current={active ? "page" : undefined}
                >
                  {item.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    ))
  }
</aside>

<style is:global>
  .sidebar {
    padding: 32px 24px;
    border-right: 1px solid var(--hairline);
  }
  .sidebar h2.section-title {
    color: var(--ink-45);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 10px;
    margin-top: 24px;
  }
  .sidebar h2.section-title:first-of-type {
    margin-top: 0;
  }
  .sidebar ul {
    padding: 0;
  }
  .sidebar li {
    margin-bottom: 2px;
  }
  .sidebar a {
    display: block;
    padding: 7px 12px;
    color: var(--ink-70);
    font-size: 0.9375rem;
    border-radius: 0;
    border-left: 2px solid transparent;
    line-height: 1.45;
  }
  .sidebar a:hover {
    color: var(--ink);
    background: var(--ink-06);
  }
  .sidebar a.active {
    color: var(--sheen);
    background: var(--ink-06);
    border-left-color: var(--sheen);
    font-weight: 500;
  }
</style>
