---
interface Props {
  kind: "proceed" | "review" | "block";
  score?: number;
}
const { kind, score } = Astro.props;
const labels = {
  proceed: "PROCEED",
  review: "REVIEW",
  block: "BLOCK",
} as const;
const glyphs = { proceed: "✓", review: "!", block: "✕" } as const;
---

<span class={`verdict verdict-${kind}`}>
  <span class="verdict-glyph" aria-hidden="true">{glyphs[kind]}</span>
  <span class="verdict-label">{labels[kind]}</span>
  {typeof score === "number" && <span class="verdict-score">{score}/100</span>}
</span>

<style is:global>
  .verdict {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    border: 1px solid transparent;
  }
  .verdict-glyph {
    font-weight: 800;
  }
  .verdict-score {
    font-weight: 500;
    opacity: 0.85;
    letter-spacing: 0;
  }
  .verdict-proceed {
    background: var(--proceed-muted);
    color: var(--success);
    border-color: var(--success);
  }
  .verdict-review {
    background: var(--review-muted);
    color: var(--warning);
    border-color: var(--warning);
  }
  .verdict-block {
    background: var(--block-muted);
    color: var(--danger);
    border-color: var(--danger);
  }
</style>
