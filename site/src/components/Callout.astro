---
interface Props {
  type?: "note" | "warn" | "tip" | "caveat";
}
const { type = "note" } = Astro.props;
---

<aside class={`callout callout-${type}`}>
  {
    type === "caveat" && (
      <span class="callout-caveat-icon" aria-hidden="true">
        ⚠
      </span>
    )
  }
  <slot />
</aside>

<style is:global>
  .callout {
    padding: 16px 18px;
    border-left: 3px solid var(--sheen);
    background: var(--ink-06);
    border-radius: 0;
    margin: 20px 0;
  }
  .callout p:last-child {
    margin-bottom: 0;
  }
  .callout strong {
    color: var(--sheen-strong);
  }
  .callout-warn {
    border-left-color: var(--danger);
  }
  .callout-warn strong {
    color: var(--danger);
  }
  .callout-tip {
    border-left-color: var(--success);
  }
  .callout-tip strong {
    color: var(--success);
  }
  .callout-caveat {
    border-left-color: var(--warning);
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .callout-caveat strong {
    color: var(--warning);
  }
  .callout-caveat-icon {
    font-size: 1.1rem;
    color: var(--warning);
    flex-shrink: 0;
    margin-top: 1px;
  }
</style>
