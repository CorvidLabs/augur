---
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { base } from "../lib/path";
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "🔮 Graded trust for code changes. Deterministic risk scoring (proceed/review/block) for humans and AI agents. No API key, no LLM.",
} = Astro.props;
// Canonical: prefer the site origin + the current pathname so crawlers don't
// treat trailing-slash/no-slash or query-string variants as duplicates.
const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url.origin,
).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Pre-paint: apply a stored/URL theme before first paint, no flash. -->
    <script is:inline>
      (() => {
        try {
          const q = new URLSearchParams(location.search).get("theme");
          const t = q || localStorage.getItem("corvid-theme");
          if (t === "light" || t === "dark")
            document.documentElement.dataset.theme = t;
        } catch (_) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}brand/favicon.svg`} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;700;900&family=Spline+Sans+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}brand/tokens.css`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <Header />
    <slot />
    <Footer />
    <script is:inline defer src={`${base}brand/theme.js`}></script>
  </body>
</html>
